# Exploratory Data Analysis (EDA)

This notebook explores:
- Crime trends
- Unemployment patterns
- Load-shedding trends

We use:
- Seaborn for static visuals
- Plotly for interactive charts

matplotlib.pyplot

crime_df = pd.read_csv("../data/cleaned_crime.csv")
unemployment_df = pd.read_csv("../data/cleaned_unemployment.csv")
load_df = pd.read_csv("../data/cleaned_loadshedding.csv")

fig = px.line(
    crime_df,
    x="year",
    y="total_crimes",
    color="province",
    title="Crime Trends by Province"
)

fig.show()

pivot = unemployment_df.pivot(
    index="province",
    columns="year",
    values="unemployment_rate"
)

plt.figure(figsize=(10,6))
sns.heatmap(pivot, annot=True, fmt=".1f", cmap="YlOrRd")
plt.title("Unemployment Rate Heatmap")
plt.show()
fig = px.bar(
    load_df,
    x="date",
    y="stage",
    color="province",
    title="Load-Shedding Stages Over Time"
)

fig.show()
fig = px.bar(
    load_df,
    x="date",
    y="stage",
    color="province",
    title="Load-Shedding Stages Over Time"
)

fig.show()

merged = pd.merge(
    crime_df,
    unemployment_df,
    on=["province", "year"],
    how="inner"
)

correlation = merged[["total_crimes", "unemployment_rate"]].corr()
correlation
sns.heatmap(correlation, annot=True, cmap="coolwarm")
plt.title("Correlation: Crime vs Unemployment")
plt.show()

