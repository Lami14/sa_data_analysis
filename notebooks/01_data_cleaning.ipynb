# Data Cleaning - South Africa Socio-Economic Data

This notebook loads and cleans datasets:
- Crime statistics
- Unemployment data
- Load-shedding data

Goal:
Prepare clean datasets for analysis and visualization.

import pandas as pd

# File paths
crime_path = "../data/crime_stats.csv"
unemployment_path = "../data/unemployment.csv"
load_path = "../data/load_shedding.csv"

crime_df = pd.read_csv(crime_path)
unemployment_df = pd.read_csv(unemployment_path)
load_df = pd.read_csv(load_path)

crime_df.head(), unemployment_df.head(), load_df.head()

def clean_columns(df):
    df.columns = df.columns.str.strip().str.lower().str.replace(" ", "_")
    return df

crime_df = clean_columns(crime_df)
unemployment_df = clean_columns(unemployment_df)
load_df = clean_columns(load_df)
# Convert year columns
if 'year' in crime_df.columns:
    crime_df['year'] = pd.to_numeric(crime_df['year'], errors='coerce')

if 'year' in unemployment_df.columns:
    unemployment_df['year'] = pd.to_numeric(unemployment_df['year'], errors='coerce')

# Convert date
if 'date' in load_df.columns:
    load_df['date'] = pd.to_datetime(load_df['date'], errors='coerce')


print("Crime Missing Values:\n", crime_df.isnull().sum())
print("\nUnemployment Missing Values:\n", unemployment_df.isnull().sum())
print("\nLoad Shedding Missing Values:\n", load_df.isnull().sum())

crime_df = crime_df.dropna()
unemployment_df = unemployment_df.dropna()
load_df = load_df.dropna()

crime_df.to_csv("../data/cleaned_crime.csv", index=False)
unemployment_df.to_csv("../data/cleaned_unemployment.csv", index=False)
load_df.to_csv("../data/cleaned_loadshedding.csv", index=False)

print("Cleaned data saved successfully!")
